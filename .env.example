# ============================================================
# IG Trading Bot — .env.example
# Скопируйте в .env и заполните своими значениями.
# ============================================================

# ---- Брокер ----
BROKER=ig                          # ig | xtb

# ---- IG API Credentials ----
IG_IDENTIFIER=your_ig_username
IG_PASSWORD=your_ig_password
IG_API_KEY=your_ig_api_key
IG_ACCOUNT_ID=your_ig_account_id   # XXXXX (5-char account ID)
IG_ACCOUNT_TYPE=demo               # demo | live
# IG_ENDPOINT=                     # авто: demo-api.ig.com / api.ig.com

# ---- XTB API Credentials (если BROKER=xtb) ----
# XTB_USER_ID=your_xtb_user_id
# XTB_PASSWORD=your_xtb_password
# XTB_APP_NAME=your_app_name
# XTB_ACCOUNT_TYPE=demo            # demo | live

# ---- Режим работы ----
IG_MODE=paper                      # signal_only | paper | execution
# IG_STRATEGY=momentum             # momentum | g1 | trend_following | crypto_trend_following | index_hybrid | mean_reversion_bb | mean_breakout_v2 | donchian_breakout | multi
# IG_FORCE_STRATEGY=false          # true — игнорировать расписание, всегда использовать IG_STRATEGY
# IG_FORCE_SYMBOLS=false           # true — игнорировать strategy-scoped символы

# ---- Символы ----
IG_SYMBOLS=EURUSD,GBPUSD,USDJPY,US100,XAUUSD,WTI
# IG_SYMBOLS_MOMENTUM=US100,US500,DE40,US30,GOLD,WTI,BRENT
# IG_SYMBOLS_TREND_FOLLOWING=US500,US30,DE40,UK100,GOLD,WTI
# IG_SYMBOLS_CRYPTO_TREND_FOLLOWING=BTC,ETH,LTC,SOL,XRP,DOGE
# IG_SYMBOLS_INDEX_HYBRID=US500,US100,DE40,UK100
# IG_SYMBOLS_G1=DE40,EURUSD,GBPUSD,USDJPY

# ---- IG Symbol Epics (JSON: символ → epic) ----
# IG_SYMBOL_EPICS={"EURUSD":"CS.D.EURUSD.CFD.IP","GBPUSD":"CS.D.GBPUSD.CFD.IP","USDJPY":"CS.D.USDJPY.CFD.IP","US100":"IX.D.NASDAQ.IFD.IP","XAUUSD":"CS.D.USCGC.TODAY.IP","WTI":"CC.D.CL.UNC.IP","BTC":"CS.D.BITCOIN.CFD.IP","ETH":"CS.D.ETHUSD.CFD.IP"}

# ---- Streaming ----
IG_STREAM_ENABLED=true             # true | false — использовать Lightstreamer
IG_STREAM_TICK_MAX_AGE_SEC=15      # максимальный возраст стрим-тика до fallback на REST
IG_REST_MARKET_MIN_INTERVAL_SEC=2.0 # минимальный интервал между REST /markets запросами

# ---- Опрос и воркеры ----
IG_POLL_INTERVAL_SEC=5.0           # интервал опроса без открытых позиций
XTB_WORKER_POLL_JITTER_SEC=1.0     # случайный разброс интервала (±сек)
# active_position_poll_interval_sec задается в strategy_params (default: min(1.0, poll_interval_sec))

# ---- Хранилище ----
# IG_STORAGE_PATH=./state/xtb_bot.db
# IG_PASSIVE_HISTORY_POLL_INTERVAL_SEC=10.0
# IG_PRICE_HISTORY_KEEP_ROWS_MIN=1000

# ---- Magic Number ----
# IG_BOT_MAGIC_PREFIX=XTBBOT
# IG_BOT_MAGIC_INSTANCE=           # авто-генерация при первом запуске

# ---- Объём ----
# IG_DEFAULT_VOLUME=0.0            # 0 = авто-расчет из риск-менеджера; > 0 = верхний лимит лота

# ---- Риск-менеджмент ----
XTB_START_BALANCE=10000.0          # стартовый баланс для расчета drawdown
XTB_MAX_RISK_PER_TRADE_PCT=1.0     # максимальный риск на сделку (%)
XTB_MAX_DAILY_DRAWDOWN_PCT=5.0     # дневная просадка → lock до следующего дня
XTB_MAX_TOTAL_DRAWDOWN_PCT=12.0    # общая просадка от start_equity
XTB_MAX_OPEN_POSITIONS=5           # лимит одновременных позиций (рекомендуемо 3..5)
# XTB_OPEN_SLOT_LEASE_SEC=30.0     # TTL резервации слота

# ---- SL / TP ----
XTB_MIN_STOP_LOSS_PIPS=10.0
XTB_MIN_TP_SL_RATIO=2.0           # TP >= SL * ratio

# ---- Trailing Stop ----
XTB_TRAILING_ACTIVATION_RATIO=0.0  # 0 = отключен; 0.5 = активация при 50% от TP
XTB_TRAILING_DISTANCE_PIPS=10.0
# XTB_TRAILING_BREAKEVEN_OFFSET_PIPS=0.0
# XTB_TRAILING_BREAKEVEN_OFFSET_PIPS_FX=0.0
# XTB_TRAILING_BREAKEVEN_OFFSET_PIPS_INDEX=0.0
# XTB_TRAILING_BREAKEVEN_OFFSET_PIPS_COMMODITY=0.0

# ---- Фильтр новостей / сессий ----
XTB_NEWS_FILTER_ENABLED=true
XTB_NEWS_EVENT_BUFFER_MIN=5
XTB_NEWS_EVENT_ACTION=breakeven    # close | breakeven
XTB_SESSION_CLOSE_BUFFER_MIN=15

# ---- Фильтр спреда ----
XTB_SPREAD_FILTER_ENABLED=true
XTB_SPREAD_ANOMALY_MULTIPLIER=3.0
XTB_SPREAD_AVG_WINDOW=50
XTB_SPREAD_MIN_SAMPLES=20
XTB_SPREAD_PCT_FILTER_ENABLED=true
# XTB_SPREAD_MAX_PCT=0.0           # общий лимит (0 = отключен)
XTB_SPREAD_MAX_PCT_CFD=0.20
XTB_SPREAD_MAX_PCT_CRYPTO=0.50

# ---- Маржа ----
XTB_MARGIN_CHECK_ENABLED=true
XTB_MARGIN_SAFETY_BUFFER=1.15
XTB_MARGIN_FALLBACK_LEVERAGE=20.0
# XTB_MARGIN_OVERHEAD_PCT=0.0
# XTB_MARGIN_WEEKEND_MULTIPLIER=1.0
# XTB_MARGIN_WEEKEND_START_HOUR_UTC=20
# XTB_MARGIN_HOLIDAY_MULTIPLIER=1.0
# XTB_MARGIN_HOLIDAY_DATES_UTC=
# XTB_MARGIN_COMMISSION_PER_LOT=0.0
# XTB_MARGIN_MIN_FREE_AFTER_OPEN=0.0
# XTB_MARGIN_MIN_FREE_AFTER_OPEN_PCT=0.0

# ---- Connectivity ----
XTB_CONNECTIVITY_CHECK_ENABLED=true
XTB_CONNECTIVITY_MAX_LATENCY_MS=500.0
XTB_CONNECTIVITY_PONG_TIMEOUT_SEC=2.0
XTB_STREAM_HEALTH_CHECK_ENABLED=true
XTB_STREAM_MAX_TICK_AGE_SEC=15.0
# XTB_STREAM_EVENT_COOLDOWN_SEC=60.0

# ---- Cashflow rebase ----
# XTB_EXTERNAL_CASHFLOW_REBASE_ENABLED=false
# XTB_EXTERNAL_CASHFLOW_REBASE_MIN_ABS=500.0
# XTB_EXTERNAL_CASHFLOW_REBASE_MIN_PCT=8.0

# ---- Логирование ----
# XTB_HOLD_REASON_LOG_INTERVAL_SEC=60.0
# XTB_WORKER_STATE_FLUSH_INTERVAL_SEC=5.0
# XTB_ACCOUNT_SNAPSHOT_PERSIST_INTERVAL_SEC=10.0

# ---- Auto-disable ----
# XTB_SYMBOL_AUTO_DISABLE_ON_EPIC_UNAVAILABLE=true
# XTB_SYMBOL_AUTO_DISABLE_EPIC_UNAVAILABLE_THRESHOLD=3
# XTB_EMERGENCY_COOLDOWN_SEC=300

# ---- Strategy Params (JSON) ----
# IG_STRATEGY_PARAMS={}
# IG_STRATEGY_PRESETS={}
# IG_STRATEGY_PARAMS_MOMENTUM={}
# IG_STRATEGY_PARAMS_G1={}
# IG_STRATEGY_PARAMS_TREND_FOLLOWING={}
# IG_STRATEGY_PARAMS_CRYPTO_TREND_FOLLOWING={}
# IG_STRATEGY_PARAMS_INDEX_HYBRID={}
# IG_STRATEGY_PARAMS_MULTI={"multi_strategies":"momentum,g1,trend_following"}  # фильтр подстратегий (по умолчанию — все)

# ---- Strategy Schedule (JSON) ----
# IG_STRATEGY_SCHEDULE='{"timezone":"UTC","slots":[...]}'
# IG_STRATEGY_SCHEDULE_TIMEZONE=UTC

# ---- Strategy Profile ----
# IG_STRATEGY_PROFILE=               # conservative | aggressive | safe
