# Optional strategy schedule (single-process hot switch without bot restart).
# Timezone defaults to UTC and should match the schedule windows below.
# If XTB_STRATEGY_SCHEDULE is set, schedule windows become the source of truth for new entries.
# Existing open positions continue to be managed by the strategy that opened them until they are closed.
# XTB_STRATEGY_SCHEDULE_TIMEZONE=UTC
# XTB_STRATEGY_SCHEDULE={"timezone":"UTC","slots":[{"label":"night_index_hybrid","strategy":"index_hybrid","symbols":["US100","US500","JPN225","UK100","AUS200"],"start":"02:30","end":"06:30","weekdays":"mon-fri","priority":20},{"label":"eu_open_index_breakout","strategy":"momentum_index","symbols":["DE40","UK100"],"start":"06:30","end":"08:30","weekdays":"mon-fri","priority":20},{"label":"eu_open_fx_breakout","strategy":"momentum_fx","symbols":["EURUSD","USDCHF","GBPUSD"],"start":"06:30","end":"08:30","weekdays":"mon-fri","priority":20},{"label":"eu_day_trend_g1","strategy":"g1","symbols":["DE40","UK100","EURUSD","GBPUSD"],"start":"08:30","end":"11:30","weekdays":"mon-fri","priority":20},{"label":"midday_mean_reversion_bb","strategy":"mean_reversion_bb","symbols":["EURGBP","EURCHF","AUDUSD","GBPUSD","AUS200"],"start":"11:30","end":"13:25","weekdays":"mon-fri","priority":20},{"label":"ny_open_index_hybrid","strategy":"index_hybrid","symbols":["US100","US500","US30"],"start":"13:30","end":"15:30","weekdays":"mon-fri","priority":20},{"label":"ny_open_commodities_breakout","strategy":"momentum_index","symbols":["DE40","GOLD","WTI","BRENT"],"start":"13:30","end":"15:30","weekdays":"mon-fri","priority":20},{"label":"us_evening_trend_following","strategy":"trend_following","symbols":["US100","US500","WTI","BRENT","GOLD"],"start":"15:30","end":"20:00","weekdays":"mon-fri","priority":20},{"label":"overnight_mean_reversion_bb","strategy":"mean_reversion_bb","symbols":["EURUSD","UK100","AUDUSD","USDCHF"],"start":"20:00","end":"23:00","weekdays":"mon-fri","priority":20},{"label":"japan_open_index","strategy":"momentum_index","symbols":["JPN225","AUS200"],"start":"23:00","end":"02:30","weekdays":"mon-fri","priority":20},{"label":"japan_open_fx","strategy":"momentum_fx","symbols":["USDJPY","AUDUSD","USDCHF"],"start":"23:00","end":"02:30","weekdays":"mon-fri","priority":20},{"label":"weekend_crypto","strategy":"crypto_trend_following","symbols":["BTC","ETH","LTC","SOL","XRP","DOGE"],"start":"00:00","end":"23:59","weekdays":"sat-sun","priority":30}]}
#XTB_STRATEGY_SCHEDULE={"timezone":"UTC","slots":[{"label":"night_index_hybrid","strategy":"index_hybrid","symbols":["US100","US500","JPN225","UK100","AUS200","DE40","FR40","EU50","US30"],"start":"02:30","end":"06:30","weekdays":"mon-fri","priority":20},{"label":"eu_open_breakout","strategy":"momentum","symbols":["US100","US500","JPN225","UK100","AUS200","DE40","FR40","EU50","US30","USDJPY","USDCHF","EURUSD","EURGBP","EURCHF","AUDUSD","GBPUSD","GBPJPY","USDCAD","GOLD","WTI","BRENT"],"start":"06:30","end":"08:30","weekdays":"mon-fri","priority":20},{"label":"eu_day_trend_g1","strategy":"g1","symbols":["US100","US500","JPN225","UK100","AUS200","DE40","FR40","EU50","US30","USDJPY","USDCHF","EURUSD","EURGBP","EURCHF","AUDUSD","GBPUSD","GBPJPY","USDCAD","GOLD","WTI","BRENT"],"start":"08:30","end":"11:30","weekdays":"mon-fri","priority":20},{"label":"midday_mean_reversion_bb","strategy":"mean_reversion_bb","symbols":["USDJPY","USDCHF","EURUSD","EURGBP","EURCHF","AUDUSD","GBPUSD","GBPJPY","USDCAD","UK100","DE40","FR40","EU50","AUS200"],"start":"11:30","end":"13:25","weekdays":"mon-fri","priority":20},{"label":"ny_open_index_hybrid","strategy":"index_hybrid","symbols":["US100","US500","JPN225","UK100","AUS200","DE40","FR40","EU50","US30","GOLD","WTI","BRENT"],"start":"13:30","end":"15:30","weekdays":"mon-fri","priority":20},{"label":"ny_open_commodities_breakout","strategy":"momentum","symbols":["US100","US500","US30","DE40","FR40","EU50","UK100","GOLD","WTI","BRENT"],"start":"13:30","end":"15:30","weekdays":"mon-fri","priority":20},{"label":"us_evening_trend_following","strategy":"trend_following","symbols":["US100","US500","JPN225","UK100","AUS200","DE40","FR40","EU50","US30","USDJPY","USDCHF","EURUSD","EURGBP","EURCHF","AUDUSD","GBPUSD","GBPJPY","USDCAD","GOLD","WTI","BRENT","XRP","DOGE","BTC","ETH","SOL","LTC"],"start":"15:30","end":"20:00","weekdays":"mon-fri","priority":20},{"label":"overnight_mean_reversion_bb","strategy":"mean_reversion_bb","symbols":["USDJPY","USDCHF","EURUSD","EURGBP","EURCHF","AUDUSD","GBPUSD","GBPJPY","USDCAD","UK100","DE40","FR40","EU50","AUS200"],"start":"20:00","end":"23:30","weekdays":"mon-fri","priority":20},{"label":"japan_opening","strategy":"momentum","symbols":["JPN225","AUS200","USDJPY","AUDUSD","USDCHF","USDCAD","GBPJPY"],"start":"23:00","end":"02:30","weekdays":"mon-fri","priority":20},{"label":"weekend_crypto","strategy":"crypto_trend_following","symbols":["XRP","DOGE","BTC","ETH","SOL","LTC"],"start":"00:00","end":"23:59","weekdays":"sat-sun","priority":30}]}

# -------------------------
# State storage and order tagging
# -------------------------
# Global storage path override (highest priority)
# BOT_STORAGE_PATH=./state/xtb_bot.db
# IG-specific storage path
# IG_STORAGE_PATH=./state/xtb_bot.db
# XTB-specific storage path
XTB_STORAGE_PATH=./state/xtb_bot.db

# SQLite runtime tuning for 24/7 mode
# Connection timeout for write lock contention (seconds)
XTB_DB_SQLITE_TIMEOUT_SEC=60
# Price-history cleanup cadence (cleanup runs every N appends per symbol)
XTB_DB_PRICE_HISTORY_CLEANUP_EVERY=5000
# Minimum time between price-history cleanups for a symbol (seconds)
XTB_DB_PRICE_HISTORY_CLEANUP_MIN_INTERVAL_SEC=30
# DB housekeeping interval (seconds). 0 = run on each monitor cycle
XTB_DB_HOUSEKEEPING_INTERVAL_SEC=300
# Max event rows to keep after housekeeping prune
XTB_DB_HOUSEKEEPING_EVENTS_KEEP_ROWS=100000
# Incremental vacuum pages per housekeeping cycle (0 disables)
XTB_DB_HOUSEKEEPING_VACUUM_PAGES=256
# Retention for IG position update lifecycle log (seconds, default: 7 days)
XTB_DB_POSITION_UPDATES_RETENTION_SEC=604800
# Async writer for multi-strategy hot/cold position tables.
XTB_MULTI_DB_ASYNC_WRITER_ENABLED=false
# Flush cadence for multi-strategy async DB writer (milliseconds).
XTB_MULTI_DB_ASYNC_FLUSH_MS=200
# Max batched operations per multi-strategy async DB transaction.
XTB_MULTI_DB_ASYNC_BATCH_SIZE=1024
# Async writer for events table (reduces write-lock contention in busy loops).
XTB_DB_EVENTS_ASYNC_WRITER_ENABLED=false
# Flush cadence for events async DB writer (milliseconds).
XTB_DB_EVENTS_ASYNC_FLUSH_MS=300
# Max batched events per async DB transaction.
XTB_DB_EVENTS_ASYNC_BATCH_SIZE=512
# DB-first /markets request target budget (requests/min).
XTB_DB_FIRST_TICK_TARGET_RPM=24
# Hard max age floor for cached DB-first ticks in broker_ticks (seconds).
# Runtime may auto-increase effective value to cover one full active-symbol cycle.
XTB_DB_FIRST_TICK_HARD_MAX_AGE_SEC=10
# How often DB-first worker prunes stale ticks from broker_ticks (seconds)
XTB_DB_FIRST_TICK_PRUNE_INTERVAL_SEC=1
# DB-first account snapshot refresh interval (seconds).
XTB_DB_FIRST_ACCOUNT_POLL_INTERVAL_SEC=15
# Runtime broker open-position sync interval when local open positions exist (seconds).
XTB_RUNTIME_BROKER_SYNC_ACTIVE_INTERVAL_SEC=8
# Runtime closed-trade detail backfill interval (seconds). Keeps `pending_broker_sync` from lingering.
XTB_RUNTIME_CLOSED_DETAILS_BACKFILL_INTERVAL_SEC=60
# Auto-report aggregated trade refusal reasons into logs + events.
XTB_TRADE_REASON_SUMMARY_ENABLED=true
# Report interval in seconds.
XTB_TRADE_REASON_SUMMARY_INTERVAL_SEC=3600
# Lookback window for each report in seconds.
XTB_TRADE_REASON_SUMMARY_WINDOW_SEC=3600
# Max events scanned per report.
XTB_TRADE_REASON_SUMMARY_SCAN_LIMIT=20000
# Max grouped reasons included in report payload.
XTB_TRADE_REASON_SUMMARY_TOP=20

# Order ownership tag prefix (3..16 chars, A-Z0-9_-)
XTB_BOT_MAGIC_PREFIX=XTBBOT
# Optional fixed bot instance id (4..20 chars, A-Za-z0-9_-)
# XTB_BOT_MAGIC_INSTANCE=

# Optional IG-prefixed aliases for magic tags
# IG_BOT_MAGIC_PREFIX=XTBBOT
# IG_BOT_MAGIC_INSTANCE=

# -------------------------
# Risk management (applies to both brokers)
# -------------------------
# Reference start balance for risk tracking
XTB_START_BALANCE=10000
# Max risk per trade in percent, allowed range: (0, 2]
XTB_MAX_RISK_PER_TRADE_PCT=0.5
# Soft drawdown throttle: start shrinking risk before hard daily/total lock.
XTB_DRAWDOWN_RISK_THROTTLE_ENABLED=true
# Start reducing per-trade risk once daily drawdown reaches this share of max daily drawdown.
XTB_DRAWDOWN_RISK_THROTTLE_DAILY_START_RATIO=0.50
# Start reducing per-trade risk once total drawdown reaches this share of max total drawdown.
XTB_DRAWDOWN_RISK_THROTTLE_TOTAL_START_RATIO=0.50
# Minimum multiplier applied to max risk per trade when soft throttle is fully engaged.
XTB_DRAWDOWN_RISK_THROTTLE_MIN_MULTIPLIER=0.50
# Daily drawdown lock threshold in percent
XTB_MAX_DAILY_DRAWDOWN_PCT=5.0
# Total drawdown emergency threshold in percent
XTB_MAX_TOTAL_DRAWDOWN_PCT=12.0
# Max simultaneous open positions, allowed range: 1..15
XTB_MAX_OPEN_POSITIONS=15
# Open-slot reservation lease in seconds for cross-process position limit guard (>0)
XTB_OPEN_SLOT_LEASE_SEC=30

# Minimum stop loss distance in pips
XTB_MIN_STOP_LOSS_PIPS=10
# Minimum TP/SL ratio, allowed range: 2.0..3.0
XTB_MIN_TP_SL_RATIO=2.2

# Trailing stop activation by progress to TP (0.0..1.0). 0.0 = activate once position is in profit.
XTB_TRAILING_ACTIVATION_RATIO=0.0
# Trailing stop distance in pips
XTB_TRAILING_DISTANCE_PIPS=10
# Legacy common fallback for all symbols if profile-specific values are not set.
XTB_TRAILING_BREAKEVEN_OFFSET_PIPS=2
# Asset profile offsets (pips)
XTB_TRAILING_BREAKEVEN_OFFSET_PIPS_FX=2
XTB_TRAILING_BREAKEVEN_OFFSET_PIPS_INDEX=8
XTB_TRAILING_BREAKEVEN_OFFSET_PIPS_COMMODITY=4
# Global adaptive ATR trailing overlay: squeezes stop when move extension gets extreme.
XTB_ADAPTIVE_TRAILING_ENABLED=true
XTB_ADAPTIVE_TRAILING_ATR_BASE_MULTIPLIER=1.0
XTB_ADAPTIVE_TRAILING_HEAT_TRIGGER=0.45
XTB_ADAPTIVE_TRAILING_HEAT_FULL=0.90
XTB_ADAPTIVE_TRAILING_DISTANCE_FACTOR_AT_FULL=0.60
XTB_ADAPTIVE_TRAILING_PROFIT_LOCK_R_AT_FULL=0.60
XTB_ADAPTIVE_TRAILING_PROFIT_LOCK_MIN_PROGRESS=0.25
XTB_ADAPTIVE_TRAILING_MIN_DISTANCE_STOP_RATIO=0.20
XTB_ADAPTIVE_TRAILING_MIN_DISTANCE_SPREAD_MULTIPLIER=1.50

# Time-based exits
# Close index positions this many minutes before session end
XTB_SESSION_CLOSE_BUFFER_MIN=15
# Enable/disable high-impact news filter: true | false
XTB_NEWS_FILTER_ENABLED=true
# News lookahead window in minutes
XTB_NEWS_EVENT_BUFFER_MIN=10
# News action: close | breakeven
XTB_NEWS_EVENT_ACTION=close

# Spread anomaly filter
# Enable spread filter: true | false
XTB_SPREAD_FILTER_ENABLED=true
# Block entries when spread > avg * multiplier (>1.0)
XTB_SPREAD_ANOMALY_MULTIPLIER=3.0
# Moving average window for spread samples (>=2)
XTB_SPREAD_AVG_WINDOW=50
# Minimum samples before spread filter activates (1..window)
XTB_SPREAD_MIN_SAMPLES=20
# Additional spread percent filter for wide-spread crypto / CFD symbols
XTB_SPREAD_PCT_FILTER_ENABLED=true
# Global percentage spread cap for all symbols. 0 = disabled.
XTB_SPREAD_MAX_PCT=0.02
# Percentage spread cap for non-FX CFDs (indices, commodities, shares)
XTB_SPREAD_MAX_PCT_CFD=0.20
# Percentage spread cap for crypto CFDs like BTC
XTB_SPREAD_MAX_PCT_CRYPTO=0.50
# Weight of spread added into stop distance for position sizing. 1.0 = fully conservative, 0.0 = ignore spread in sizing.
XTB_SPREAD_RISK_WEIGHT=0.75

# Margin pre-check before opening new position
# Enable/disable margin sufficiency check: true | false
XTB_MARGIN_CHECK_ENABLED=true
# Safety multiplier for estimated required margin (>=1.0)
XTB_MARGIN_SAFETY_BUFFER=1.15
# Fallback leverage when broker spec does not expose margin factor/leverage (>0)
XTB_MARGIN_FALLBACK_LEVERAGE=20
# Minimum allowed margin level in percent, checked both before and after opening a trade. 0 = disabled.
XTB_MARGIN_MIN_LEVEL_PCT=200.0
# Extra local overhead on required margin estimate in percent (0 = disabled).
# Suggested live range: 1.0 .. 5.0
XTB_MARGIN_OVERHEAD_PCT=2.5
# Weekend multiplier for required margin from Friday evening UTC through weekend.
# Suggested live range: 1.15 .. 1.40
XTB_MARGIN_WEEKEND_MULTIPLIER=1.3
# Friday UTC hour when weekend margin multiplier starts (0..23)
XTB_MARGIN_WEEKEND_START_HOUR_UTC=20
# Extra multiplier for configured UTC holiday dates.
# Suggested live range: 1.10 .. 1.40
XTB_MARGIN_HOLIDAY_MULTIPLIER=1.0
# Comma-separated UTC dates (YYYY-MM-DD) for elevated holiday margin.
# Example: 2026-12-24,2026-12-25,2026-12-31
XTB_MARGIN_HOLIDAY_DATES_UTC=
# Fixed commission reserve added per lot to required margin estimate.
XTB_MARGIN_COMMISSION_PER_LOT=0.0
# Absolute free-margin reserve required after opening a new trade.
XTB_MARGIN_MIN_FREE_AFTER_OPEN=0.0
# Percent-of-equity free-margin reserve required after opening a new trade.
XTB_MARGIN_MIN_FREE_AFTER_OPEN_PCT=0.0
# Rebase risk anchors when a large, transfer-like equity+balance jump is detected.
# Helps avoid false daily drawdown locks after account transfers.
XTB_EXTERNAL_CASHFLOW_REBASE_ENABLED=false
# Minimum absolute jump for rebase detection (account currency).
XTB_EXTERNAL_CASHFLOW_REBASE_MIN_ABS=500.0
# Minimum relative jump for rebase detection (% of previous balance).
XTB_EXTERNAL_CASHFLOW_REBASE_MIN_PCT=8.0

# Connectivity guard before opening new trades
# Enable connectivity check: true | false
XTB_CONNECTIVITY_CHECK_ENABLED=true
# Max allowed API latency in milliseconds (>0)
XTB_CONNECTIVITY_MAX_LATENCY_MS=900
# Max wait for PONG in seconds (>0)
XTB_CONNECTIVITY_PONG_TIMEOUT_SEC=2

# Stream health guard
# Enable stream health check: true | false
XTB_STREAM_HEALTH_CHECK_ENABLED=true
# Max allowed tick staleness in seconds (>0)
XTB_STREAM_MAX_TICK_AGE_SEC=15
# Global max age of tick for opening NEW positions across all strategies (seconds, >=0).
# 0 = auto mode (worker picks adaptive default). Strategy-specific *_entry_tick_max_age_sec still overrides this.
XTB_ENTRY_TICK_MAX_AGE_SEC=5
# Cooldown between repeating stream alerts in seconds (>0)
XTB_STREAM_EVENT_COOLDOWN_SEC=60
# How often to write HOLD diagnostics (seconds, >0).
# If HOLD reason changes, it is logged immediately.
XTB_HOLD_REASON_LOG_INTERVAL_SEC=60
# Minimum interval between unchanged worker state writes to SQLite (seconds, >0).
XTB_WORKER_STATE_FLUSH_INTERVAL_SEC=5
# Minimum interval between account snapshot writes to SQLite (seconds, >0).
XTB_ACCOUNT_SNAPSHOT_PERSIST_INTERVAL_SEC=10

# Auto-disable symbol worker if IG market epic is unavailable repeatedly.
# true = disable the symbol thread after N consecutive epic.unavailable errors.
XTB_SYMBOL_AUTO_DISABLE_ON_EPIC_UNAVAILABLE=true
# N consecutive epic.unavailable errors before symbol is disabled (>=1).
XTB_SYMBOL_AUTO_DISABLE_EPIC_UNAVAILABLE_THRESHOLD=3

# Emergency cooldown after force-flatten (seconds)
XTB_EMERGENCY_COOLDOWN_SEC=300