# =========================
# Single configuration file
# =========================
# Use this file as the only config source:
#   cp .env.example .env
# Do not use JSON config files.

# -------------------------
# Broker selection
# -------------------------
# Main broker selector: ig | xtb
BROKER=ig

# Optional aliases for BROKER (normally leave empty)
# IG_BROKER=ig
# XTB_BROKER=xtb

# -------------------------
# IG credentials / connection
# -------------------------
# IG login identifier
IG_IDENTIFIER=
# IG password
IG_PASSWORD=
# IG REST API key
#IG_API_KEY=
IG_API_KEY=
# App name sent in API session
IG_APP_NAME=
# IG account type: demo | live
IG_ACCOUNT_TYPE=demo
IG_STRATEGY_PROFILE=aggressive

##### SYNC AFTER THIS LINE ######
# Optional explicit IG account id (if multiple accounts)
# IG_ACCOUNT_ID=
# Optional IG REST endpoint override
# IG_ENDPOINT=https://demo-api.ig.com/gateway/deal
# Enable IG Lightstreamer stream cache: true | false
IG_STREAM_ENABLED=true
# Use official Lightstreamer Python SDK for IG stream transport (recommended).
# Falls back to legacy internal transport when SDK is missing.
IG_STREAM_SDK_ENABLED=true
# Enable /markets search fallback for epic discovery.
IG_EPIC_SEARCH_ENABLED=true
# Max age (sec) for stream tick before REST fallback in get_price
IG_STREAM_TICK_MAX_AGE_SEC=15
# Max age (sec) of stream tick that is still allowed to be reused to avoid REST storms.
IG_STREAM_STALE_TICK_MAX_AGE_SEC=180
# Minimum delay (sec) between REST fallbacks per symbol when stream is connected.
IG_STREAM_REST_FALLBACK_MIN_INTERVAL_SEC=30
# Global minimum delay (sec) between IG /markets REST requests (rate-limit guard)
IG_REST_MARKET_MIN_INTERVAL_SEC=1.5
# Upper bound for adaptive IG /markets REST delay after allowance errors.
IG_REST_MARKET_MIN_INTERVAL_MAX_SEC=12.0
# Shared cache TTL for IG connectivity probe (GET /session), seconds.
IG_CONNECTIVITY_STATUS_CACHE_TTL_SEC=10
# Shared cache TTL for unhealthy connectivity probe state, seconds.
IG_CONNECTIVITY_STATUS_UNHEALTHY_CACHE_TTL_SEC=2
# Bot-level local budget for IG non-trading requests (all DB-first/runtime sync paths).
XTB_IG_NON_TRADING_BUDGET_ENABLED=true
# Sustained local budget (requests/min, keep below account non-trading limit=30/min).
XTB_IG_NON_TRADING_BUDGET_RPM=24
# Reserve part of local non-trading budget for account/spec/runtime sync (requests/min).
XTB_IG_NON_TRADING_BUDGET_RESERVE_RPM=12
# Burst for local non-trading budget.
XTB_IG_NON_TRADING_BUDGET_BURST=4
# How often to log local budget deferrals.
XTB_IG_NON_TRADING_BUDGET_WARN_INTERVAL_SEC=30
# Warn threshold for IG account non-trading usage from ig_rate_limit_workers.
XTB_IG_ACCOUNT_NON_TRADING_WARN_AT=24
# Optional proxy layer on top of IgApiClient for extra read caching + token-bucket limits.
XTB_IG_PROXY_ENABLED=false
# Optional background cache pollers for proxy (account/news pre-refresh).
XTB_IG_PROXY_POLLERS_ENABLED=false
# Sustained account non-trading read budget for proxy (requests/min).
XTB_IG_PROXY_ACCOUNT_NON_TRADING_PER_MIN=25
# Burst capacity for account non-trading proxy bucket.
XTB_IG_PROXY_ACCOUNT_NON_TRADING_BURST=5
# Sustained account trading budget for proxy (requests/min).
XTB_IG_PROXY_ACCOUNT_TRADING_PER_MIN=100
# Burst capacity for account trading proxy bucket.
XTB_IG_PROXY_ACCOUNT_TRADING_BURST=10
# Cooldown (sec) before retrying symbols that returned persistent epic unavailable errors.
IG_EPIC_UNAVAILABLE_RETRY_SEC=45
# Cooldown (sec) for EPIC that returned instrument.invalid on trade open.
IG_INVALID_EPIC_RETRY_SEC=1800
# Global minimum delay (sec) between critical trade operations (open/close/modify)
IG_TRADE_SUBMIT_MIN_INTERVAL_SEC=1.0
# Guaranteed stop mode for IG open orders: off | auto | required
# auto = enable guaranteed stop only when market rules/reject history indicate requirement.
# Runtime can auto-mark a symbol as guaranteed-stop-required if a stop-loss close shows
# severe slippage versus planned SL (see stop_slippage_auto_guaranteed_stop_* strategy params).
IG_GUARANTEED_STOP_MODE=auto
# Force-open flag for IG market orders (true keeps opposite-direction positions independent).
IG_OPEN_FORCE_OPEN=true
# Optional market-order entry tolerance (in pips). 0 disables level guard.
IG_OPEN_LEVEL_TOLERANCE_PIPS=0.0
# Optional quoteId pinning for market orders (only if /markets snapshot provides quoteId).
IG_OPEN_USE_QUOTE_ID=false
# Optional symbol->epic mapping as JSON object
IG_SYMBOL_EPICS={"EURUSD":"CS.D.EURUSD.CFD.IP","GBPUSD":"CS.D.GBPUSD.CFD.IP","USDJPY":"CS.D.USDJPY.CFD.IP","USDCHF":"CS.D.USDCHF.CFD.IP","USDCAD":"CS.D.USDCAD.CFD.IP","EURGBP":"CS.D.EURGBP.CFD.IP","EURCHF":"CS.D.EURCHF.CFD.IP","AUDUSD":"CS.D.AUDUSD.CFD.IP","GBPJPY":"CS.D.GBPJPY.CFD.IP","US100":"IX.D.NASDAQ.CASH.IP","US500":"IX.D.SPTRD.DAILY.IP","US30":"IX.D.DOW.DAILY.IP","US2000":"IX.D.RUSSELL.IFM.IP","DE40":"IX.D.DAX.DAILY.IP","UK100":"IX.D.FTSE.DAILY.IP","FR40":"IX.D.CAC.DAILY.IP","EU50":"IX.D.STXE.IFD.IP","IT40":"IX.D.MIB.IFD.IP","ES35":"IX.D.IBEX.FWS1.IP","SK20":"IX.D.OMX.IFD.IP","NK20":"IX.D.OBX.IFD.IP","JPN225":"IX.D.NIKKEI.DAILY.IP","TOPIX":"IX.D.TOPIX.IFU.IP","AUS200":"IX.D.ASX.IFS.IP","GOLD":"CS.D.CFDGOLD.CFDGC.IP","WTI":"CC.D.CL.UNC.IP","BRENT":"CC.D.LCO.USS.IP"}

# -------------------------
# XTB credentials / connection
# -------------------------
# Used only when BROKER=xtb
XTB_USER_ID=123456
XTB_PASSWORD=your_password
XTB_APP_NAME=xtb-bot
# XTB account type: demo | live
XTB_ACCOUNT_TYPE=demo
# Optional XTB endpoint override
# XTB_ENDPOINT=wss://xapi.xtb.com/demo
# Optional control-socket keepalive (seconds). 0 disables background keepalive pings.
XTB_CONTROL_KEEPALIVE_INTERVAL_SEC=25
# Timeout for low-level control-socket PONG wait used by keepalive.
XTB_CONTROL_KEEPALIVE_PING_TIMEOUT_SEC=2.0

# -------------------------
# Runtime mode and market scope
# -------------------------
# Bot mode: signal_only | paper | execution
XTB_MODE=execution
# Strict connect mode: true = fail startup if broker connect/login fails.
# false = in paper/signal modes bot may fallback to MockBrokerClient.
BOT_STRICT_BROKER_CONNECT=false
# Strategy id (available list: xtb-bot --list-strategies)
XTB_STRATEGY=momentum
# Momentum aliases (same strategy class, different presets/schedules):
# - momentum_index
# - momentum_fx
# Optional built-in profile for active strategy.
# Supported strategies (all support safe|conservative|aggressive):
# - momentum, momentum_index, momentum_fx, g1, g2, trend_following
# - donchian_breakout, index_hybrid, mean_breakout_v2, mean_reversion_bb
# BOT_STRATEGY_PROFILE=conservative
# IG_STRATEGY_PROFILE=aggressive
# XTB_STRATEGY_PROFILE=conservative
# Trading symbols, comma separated (fallback if strategy-specific list is not set)
XTB_SYMBOLS=US100,US2000,US500,JPN225,TOPIX,UK100,AUS200,DE40,FR40,EU50,IT40,ES35,SK20,NK20,US30,USDJPY,USDCHF,EURUSD,EURGBP,EURCHF,AUDUSD,GBPUSD,GBPJPY,USDCAD,GOLD,WTI,BRENT
# Strategy-scoped symbols (auto-picked by active strategy):
# Pattern: XTB_SYMBOLS_<STRATEGY> / IG_SYMBOLS_<STRATEGY>
# All current strategies:
XTB_SYMBOLS_MOMENTUM=US100,US2000,US500,JPN225,TOPIX,UK100,AUS200,DE40,FR40,EU50,IT40,ES35,SK20,NK20,US30,USDJPY,USDCHF,EURUSD,EURGBP,EURCHF,AUDUSD,GBPUSD,GBPJPY,USDCAD,GOLD,WTI,BRENT
XTB_SYMBOLS_MOMENTUM_INDEX=US100,US2000,US500,JPN225,TOPIX,UK100,AUS200,DE40,FR40,EU50,IT40,ES35,SK20,NK20,US30
XTB_SYMBOLS_MOMENTUM_FX=USDJPY,USDCHF,EURUSD,EURGBP,EURCHF,AUDUSD,GBPUSD,GBPJPY,USDCAD
XTB_SYMBOLS_G1=US100,US2000,US500,JPN225,TOPIX,UK100,AUS200,DE40,FR40,EU50,IT40,ES35,SK20,NK20,US30,USDJPY,USDCHF,EURUSD,EURGBP,EURCHF,AUDUSD,GBPUSD,GBPJPY,USDCAD,GOLD,WTI,BRENT
XTB_SYMBOLS_G2=US100,US2000,US500,JPN225,TOPIX,UK100,AUS200,DE40,FR40,EU50,IT40,ES35,SK20,NK20,US30
XTB_SYMBOLS_DONCHIAN_BREAKOUT=US100,US2000,US500,JPN225,TOPIX,UK100,AUS200,DE40,FR40,EU50,IT40,ES35,SK20,NK20,US30,USDJPY,USDCHF,EURUSD,EURGBP,EURCHF,AUDUSD,GBPUSD,GBPJPY,USDCAD,GOLD,WTI,BRENT
XTB_SYMBOLS_INDEX_HYBRID=US100,US2000,US500,JPN225,TOPIX,UK100,AUS200,DE40,FR40,EU50,IT40,ES35,SK20,NK20,US30
XTB_SYMBOLS_MEAN_BREAKOUT_V2=US100,US2000,US500,JPN225,TOPIX,UK100,AUS200,DE40,FR40,EU50,IT40,ES35,SK20,NK20,US30,USDJPY,USDCHF,EURUSD,EURGBP,EURCHF,AUDUSD,GBPUSD,GBPJPY,USDCAD,GOLD,WTI,BRENT
XTB_SYMBOLS_MEAN_REVERSION_BB=US100,US2000,US500,JPN225,TOPIX,UK100,AUS200,DE40,FR40,EU50,IT40,ES35,SK20,NK20,US30,USDJPY,USDCHF,EURUSD,EURGBP,EURCHF,AUDUSD,GBPUSD,GBPJPY,USDCAD
XTB_SYMBOLS_TREND_FOLLOWING=US100,US2000,US500,JPN225,TOPIX,UK100,AUS200,DE40,FR40,EU50,IT40,ES35,SK20,NK20,US30,USDJPY,USDCHF,EURUSD,EURGBP,EURCHF,AUDUSD,GBPUSD,GBPJPY,USDCAD,GOLD,WTI,BRENT
#XTB_SYMBOLS_CRYPTO_TREND_FOLLOWING=XRP,DOGE,BTC,ETH,SOL,LTC
# Optional IG-prefixed aliases (same behavior, higher priority for BROKER=ig)
# IG_SYMBOLS_MOMENTUM=US100,US500,DE40,US30,GOLD,WTI,BRENT
# IG_SYMBOLS_MOMENTUM_INDEX=US100,US500,DE40,US30
# IG_SYMBOLS_MOMENTUM_FX=EURUSD,GBPUSD,USDJPY
# IG_SYMBOLS_G1=EURUSD,GBPUSD,USDJPY,US100
# IG_SYMBOLS_G2=US100,US2000,US500,JPN225,TOPIX,DE40,UK100
# IG_SYMBOLS_DONCHIAN_BREAKOUT=US100,US500,JPN225,TOPIX,UK100,AUS200,DE40,FR40,EU50,IT40,ES35,SK20,DEMID50,US30,USDJPY,USDCHF,EURUSD,EURGBP,EURCHF,AUDUSD,GBPUSD,GBPJPY,USDCAD,GOLD,WTI,BRENT,CARBON,UKNATGAS,GASOLINE,WHEAT,COCOA,CORN,SOYBEANOIL,OATS,XRP,DOGE,BTC,ETH,SOL,LTC
# IG_SYMBOLS_INDEX_HYBRID=US500,US100,US2000,JPN225,TOPIX,DE40,FR40,EU50,IT40,ES35,SK20,DEMID50,UK100
# IG_SYMBOLS_MEAN_BREAKOUT_V2=US100,US2000,JPN225,TOPIX,WTI,USDJPY,DE40,GOLD,CARBON,UKNATGAS,GASOLINE,WHEAT,COCOA,CORN,SOYBEANOIL,OATS
# IG_SYMBOLS_MEAN_REVERSION_BB=US100,US500,JPN225,TOPIX,UK100,AUS200,DE40,FR40,EU50,IT40,ES35,SK20,DEMID50,US30,USDJPY,USDCHF,EURUSD,EURGBP,EURCHF,AUDUSD,GBPUSD,GBPJPY,USDCAD
# IG_SYMBOLS_TREND_FOLLOWING=US500,US2000,US30,JPN225,TOPIX,DE40,FR40,EU50,IT40,ES35,SK20,DEMID50,UK100,GOLD,WTI,BRENT,CARBON,UKNATGAS,GASOLINE,WHEAT,COCOA,CORN,SOYBEANOIL,OATS,AAPL,MSFT
# Legacy compatibility for older configs (index_hybrid only):
# IG_INDEX_HYBRID_SYMBOLS=US500,US100,US2000,JPN225,TOPIX,DE40,UK100
# XTB_INDEX_HYBRID_SYMBOLS=US500,US100,US2000,JPN225,TOPIX,DE40,UK100
# Loop interval in seconds
XTB_POLL_INTERVAL_SEC=5
# Per-worker random jitter for polling loop in seconds (desynchronizes API calls)
XTB_WORKER_POLL_JITTER_SEC=1.0
# Background history refresh interval for symbols that are currently inactive.
XTB_PASSIVE_HISTORY_POLL_INTERVAL_SEC=60
# Hard cap for passive history REST fetches per monitor cycle.
XTB_PASSIVE_HISTORY_MAX_SYMBOLS_PER_CYCLE=2
# Minimum retained history rows per symbol in SQLite (active + passive cache).
XTB_PRICE_HISTORY_KEEP_ROWS_MIN=500000
# Position size cap (0 = disabled, use full dynamic risk sizing)
XTB_DEFAULT_VOLUME=0

# Strategy params (layered):
# 1) XTB_STRATEGY_PARAMS                      -> global keys for all strategies
# 2) XTB_STRATEGY_PRESETS[active_strategy]    -> optional map with per-strategy objects
# 3) XTB_STRATEGY_PARAMS_<ACTIVE_STRATEGY>    -> highest priority
#
# Keep only shared keys in global layer:
# Multi-strategy runtime/netting knobs are configured here explicitly (no hidden defaults).
XTB_STRATEGY_PARAMS={"stop_loss_pips":25,"take_profit_pips":50,"entry_tick_max_age_sec":1.5,"worker_connectivity_check_interval_sec":5.0,"continuation_reentry_guard_enabled":true,"continuation_reentry_reset_on_opposite_signal":true,"continuation_reentry_post_win_reset_guard_enabled":true,"continuation_reentry_post_win_min_reset_stop_ratio":0.25,"continuation_reentry_post_win_max_age_sec":1200.0,"hold_reason_metadata_verbosity":"basic","protective_peak_drawdown_exit_enabled":true,"protective_peak_drawdown_ratio":0.25,"protective_peak_drawdown_min_peak_pips":4.0,"protective_peak_drawdown_hard_exit_enabled":true,"protective_breakeven_lock_enabled":true,"protective_breakeven_min_peak_pips":4.0,"protective_breakeven_min_tp_progress":0.55,"protective_breakeven_offset_pips":0.0,"trailing_breakeven_offset_pips":2.5,"protective_peak_stagnation_exit_enabled":true,"protective_peak_stagnation_timeout_sec":420.0,"protective_peak_stagnation_min_peak_pips":8.0,"protective_peak_stagnation_min_retain_ratio":0.55,"protective_peak_drawdown_ratio_by_symbol":{"WTI":0.30,"AUS200":0.18,"USDCHF":0.28,"US100":0.20,"US500":0.20,"US30":0.20,"DE40":0.20,"UK100":0.20,"JPN225":0.20},"protective_peak_drawdown_min_peak_pips_by_symbol":{"WTI":3.0,"AUS200":3.0,"USDCHF":2.0},"protective_breakeven_min_peak_pips_by_symbol":{"WTI":3.0,"AUS200":3.0,"USDCHF":2.0},"protective_peak_stagnation_timeout_sec_by_symbol":{"WTI":300.0,"AUS200":300.0,"USDCHF":300.0},"protective_peak_stagnation_min_retain_ratio_by_symbol":{"WTI":0.65,"AUS200":0.65,"USDCHF":0.60},"protective_stale_loser_exit_enabled":true,"protective_stale_loser_timeout_sec":1800.0,"protective_stale_loser_timeout_sec_by_symbol":{"AUS200":1200.0},"protective_stale_loser_loss_ratio":0.55,"protective_stale_loser_loss_ratio_by_symbol":{"AUS200":0.35},"protective_stale_loser_profit_tolerance_pips":0.0,"protective_fast_fail_exit_enabled":true,"protective_fast_fail_timeout_sec":300.0,"protective_fast_fail_timeout_sec_by_symbol":{"WTI":300.0,"AUS200":120.0,"